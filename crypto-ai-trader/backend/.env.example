# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Binance (get from binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_TESTNET=true

# OKX (get from okx.com/account/my-api)
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_PASSPHRASE=your_okx_passphrase
OKX_TESTNET=true

# Hyperliquid (your ETH wallet private key)
HYPERLIQUID_PRIVATE_KEY=your_private_key_0x...
HYPERLIQUID_TESTNET=true

# Security
SECRET_KEY=change_this_to_a_random_string_in_production

# Risk Management
MAX_POSITION_SIZE_PCT=0.05
MAX_DRAWDOWN_PCT=0.15
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=10
